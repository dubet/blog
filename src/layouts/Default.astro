---
import ScreenTooSmall from '@components/ScreenTooSmall.astro';

import '@styles/theme.css';

import { initLocale, Locale } from '@common';

interface Props {
	title: string;
	locale: Locale;
}

const { title, locale } = Astro.props;

const T = initLocale(locale);

---

<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/assets/favicon.svg" />
		<link rel="preload" href="/assets/fonts/Cubano.woff2" as="font" type="font/woff2" crossorigin>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={T("meta.description")}>
		<title>{title}</title>
	</head>
	<body>
		<svg class="hidden">
			<!--!Font Awesome Free 6.7.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2024 Fonticons, Inc.-->
