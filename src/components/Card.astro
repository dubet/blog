---
import BuildingIcon from './icons/Building.astro';
import CalendarIcon from './icons/Calendar.astro';
import LocationDotIcon from './icons/LocationDot.astro';

interface Props {
	label: string;
	years: string;
	host: string;
	location: string;
	content?: string[];
	tags?: string[];
}

const { label, years, host, location, content, tags } = Astro.props;
---

<div class="flex w-full flex-col gap-4 rounded-lg p-4 bg-2nd text-black">
	<h2 class="text-center text-[1.3rem] font-bold">{label}</h2>
	<div class="w-full flex flex-wrap justify-center gap-2">
		<span class="vignette-item">
			<span class="h-6 w-6 shrink-0">
				<CalendarIcon />
			</span>
			{years}
		</span>
		<span class="vignette-item">
			<span class="h-6 w-6 shrink-0">
				<BuildingIcon />
			</span>
			{host}
		</span>
		<span class="vignette-item">
			<span class="h-6 w-6 shrink-0">
				<LocationDotIcon />
			</span>
			{location}
		</span>
	</div>
	{
		content ? <ul class="list-disc px-4">{content.map((entry: string) => <li>{entry}</li>)}</ul> : null
	}
	<div class=" flex flex-wrap justify-center gap-2">
		{
			tags?.map((t: string) => (
				<span class="experience-tag transition hover:scale-140 cursor-pointer hover:shadow-lg">
					{t}
				</span>
			))
		}
	</div>
</div>
