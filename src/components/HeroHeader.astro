---
import type { Locale } from "@common";
import ScrollButton from "./ScrollButton.astro";
import FeatherPointedIcon from "./icons/FeatherPointed.astro";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
---

<header class=" min-h-svh flex-col items-center justify-center gap-4 text-white flex bg-1st">
	<div class="flex items-center gap-4">
		{["en", "fr"].map((l: string) => (
			l == locale
				? undefined
				: <a href={"/" + l + "/"} class="hero-button text-xl">{l.toUpperCase()}</a>
		))}
	</div>
	<h1 class="text-7xl font-thin fg-white">dubet.fr</h1>
	<div class="flex items-center justify-center gap-4">
	<ScrollButton />
	<a aria-label="Got to articles button" title="Go to articles button" href={`/${locale}/articles`} class="hero-button cursor-pointer">
		<div class="h-10 w-10">
			<FeatherPointedIcon />
		</div>
	</a>
	</div>
</header>
