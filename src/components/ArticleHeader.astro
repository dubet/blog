---
import type { Locale } from "@common";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
---

<header class="bg-1st">
	<div class="flex items-center justify-between gap-4 text-white md:max-w-5xl xl:max-w-5xl mx-auto px-4 py-8">
		<div class="flex gap-4">
			<a class="text-5xl font-bold text-white hover:text-2nd" href={`/${locale}`}>dubet.fr</a>
		</div>
	</div>
</header>
